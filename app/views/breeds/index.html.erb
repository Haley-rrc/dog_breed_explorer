<div class="mb-4">
  <h1 class="display-5 fw-bold">Dog Breeds</h1>

  <p class="lead">
    Browse and search dog breeds collected from the Dog CEO API.
  </p>
</div>

<%= form_with url: breeds_path,
              method: :get,
              local: true,
              class: "search-form mb-4" do |form| %>

  <div class="row g-3 align-items-end">
    <div class="col-12 col-lg-4">
      <%= form.label :query,
                     "Search by breed name",
                     class: "form-label fw-bold" %>

      <%= form.text_field :query,
                          value: params[:query],
                          placeholder: "Example: Husky",
                          class: "form-control" %>
    </div>

    <div class="col-12 col-lg-4">
      <%= form.label :sub_breed_id,
                     "Filter by sub-breed",
                     class: "form-label fw-bold" %>

      <%= form.select :sub_breed_id,
          options_for_select(
            [["All sub-breeds", ""]] +
            @sub_breeds.map do |sub_breed|
              [
                "#{sub_breed.name} (#{sub_breed.breed.name})",
                sub_breed.id
              ]
            end,
            params[:sub_breed_id]
          ),
          {},
          class: "form-select" %>
    </div>

    <div class="col-12 col-lg-2">
      <div class="form-check">
        <%= form.check_box :featured,
                           {
                             checked: params[:featured] == "1",
                             class: "form-check-input"
                           },
                           "1",
                           "0" %>

        <%= form.label :featured,
                       "Featured only",
                       class: "form-check-label" %>
      </div>
    </div>

    <div class="col-12 col-lg-2">
      <%= form.submit "Search",
                      class: "btn btn-primary me-2" %>

      <% if params[:query].present? ||
            params[:sub_breed_id].present? ||
            params[:featured] == "1" %>

        <%= link_to "Clear",
                    breeds_path,
                    class: "btn btn-outline-secondary mt-2 mt-xl-0" %>
      <% end %>
    </div>
  </div>
<% end %>

<p class="mb-4">
  <strong>Total results:</strong>
  <%= @breeds.total_count %>

  <% if @breeds.total_pages > 1 %>
    <span class="text-muted">
      — Page <%= @breeds.current_page %>
      of <%= @breeds.total_pages %>
    </span>
  <% end %>
</p>

<% if @breeds.any? %>
  <div class="row g-4">
    <% @breeds.each do |breed| %>
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <% if breed.dog_images.any? %>
            <%= image_tag breed.dog_images.first.image_url,
                          alt: breed.name,
                          class: "card-img-top breed-card-image" %>
          <% else %>
            <div class="no-image-placeholder">
              No image available
            </div>
          <% end %>

          <div class="card-body d-flex flex-column">
            <h2 class="card-title h4">
              <%= breed.name %>
            </h2>

            <p class="card-text">
              <%= breed.description %>
            </p>

            <% if breed.featured? %>
              <p>
                <span class="badge text-bg-warning">
                  Featured Breed
                </span>
              </p>
            <% end %>

            <% if breed.sub_breeds.any? %>
              <div class="mb-3">
                Sub-breeds:

                <ul class="mb-0">
                  <% breed.sub_breeds.order(:name).limit(3).each do |sub_breed| %>
                    <li>
                      <%= link_to sub_breed.name,
                                  sub_breed_path(sub_breed) %>
                    </li>
                  <% end %>
                </ul>

                <% if breed.sub_breeds.count > 3 %>
                  <small class="text-muted">
                    And <%= breed.sub_breeds.count - 3 %> more
                  </small>
                <% end %>
              </div>
            <% else %>
              <p class="text-muted">
                No sub-breeds
              </p>
            <% end %>

            <div class="mt-auto">
              <%= link_to "View Breed",
                          breed_path(breed),
                          class: "btn btn-primary" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="pagination-wrapper mt-5">
    <%= paginate @breeds,
                 params: request.query_parameters.except(:page) %>
  </div>
<% else %>
  <div class="alert alert-warning">
    No breeds matched your search.
  </div>
<% end %>