<h1>Dog Breeds</h1>

<p>
  Browse all dog breeds collected from the Dog CEO API.
</p>


<%= form_with url: breeds_path, method: :get, local: true do |form| %>
  <div class="search-form">
    <%= form.label :query, "Search by breed name" %>

    <%= form.text_field :query,
                        value: params[:query],
                        placeholder: "Example: Husky" %>

    <%= form.submit "Search" %>

    <% if params[:query].present? %>
      <%= link_to "Clear", breeds_path %>
    <% end %>
  </div>
<% end %>

<p>
  Results: <%= @breeds.count %>
</p>

<% if @breeds.any? %>
  <div class="breed-list">
    <% @breeds.each do |breed| %>
      <section class="breed-card">
        <h2>
          <%= link_to breed.name, breed_path(breed) %>
        </h2>

        <p><%= breed.description %></p>

        <% if breed.featured? %>
          <p><strong>Featured Breed</strong></p>
        <% end %>

        <% if breed.dog_images.any? %>
          <%= image_tag breed.dog_images.first.image_url,
                        alt: breed.name,
                        class: "breed-image" %>
        <% else %>
          <p>No image available.</p>
        <% end %>

        <p>
          <%= link_to "View Breed", breed_path(breed) %>
        </p>
      </section>
    <% end %>
  </div>
<% else %>
  <p>No breeds matched.</p>
<% end %>