<div class="mb-4">
  <%= link_to "← Back to All Breeds",
              breeds_path,
              class: "btn btn-outline-secondary mb-3" %>

  <h1 class="display-5 fw-bold">
    <%= @breed.name %>
  </h1>

  <p class="lead">
    <%= @breed.description %>
  </p>

  <% if @breed.featured? %>
    <span class="badge text-bg-warning mb-3">
      Featured Breed
    </span>
  <% end %>
</div>

<section class="mb-5">
  <h2>Sub-breeds</h2>

  <% if @breed.sub_breeds.any? %>
    <div class="list-group">
      <% @breed.sub_breeds.order(:name).each do |sub_breed| %>
        <%= link_to sub_breed_path(sub_breed),
                    class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do %>

          <span><%= sub_breed.name %></span>
          <span>View →</span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-secondary">
      This breed has no sub-breeds.
    </div>
  <% end %>
</section>

<section>
  <h2>Dog Images</h2>

  <% if @breed.dog_images.any? %>
    <div class="row g-4">
      <% @breed.dog_images.each do |dog_image| %>
        <div class="col-12 col-md-6 col-lg-4">
          <figure class="card h-100 shadow-sm">
            <%= image_tag dog_image.image_url,
                          alt: dog_image.caption,
                          class: "card-img-top breed-detail-image" %>

            <figcaption class="card-body">
              <%= dog_image.caption %>
            </figcaption>
          </figure>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-warning">
      No images are available for this breed.
    </div>
  <% end %>
</section>