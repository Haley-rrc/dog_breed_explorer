<div class="mb-4">
  <%= link_to "← Back to #{@breed.name}",
              breed_path(@breed),
              class: "btn btn-outline-secondary mb-3" %>

  <h1 class="display-5 fw-bold">
    <%= @dog_image.caption %>
  </h1>

  <p class="lead">
    This image belongs to
    <%= link_to @breed.name, breed_path(@breed) %>.
  </p>
</div>

<div class="row justify-content-center">
  <div class="col-12 col-lg-9">
    <div class="card shadow-sm">
      <%= image_tag @dog_image.image_url,
                    alt: @dog_image.caption,
                    class: "dog-image-large" %>

      <div class="card-body">
        <h2 class="h4">Image Information</h2>

        <p>
          Caption:
          <%= @dog_image.caption %>
        </p>

        <p>
          Breed:
          <%= link_to @breed.name, breed_path(@breed) %>
        </p>

        <% if @breed.sub_breeds.any? %>
          <p>
            Sub-breeds:
          </p>

          <ul>
            <% @breed.sub_breeds.order(:name).each do |sub_breed| %>
              <li>
                <%= link_to sub_breed.name,
                            sub_breed_path(sub_breed) %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted">
            This breed has no sub-breeds.
          </p>
        <% end %>
      </div>
    </div>
  </div>
</div>